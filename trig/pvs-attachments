;;-*-Lisp-*-
;;These attachments allow for dynamic binding of functions according to
;;the theories that are imported, e.g., fast_approx@pvsio, exact_real_arith@pvsio

(defattach |pi_def.pi| ()
  "Number π"
  (cond
   ((check-name "fast_approx@pvsio.FastApproxIO__")
    (pvsio-funcall "fast_approx.pi_fast_approx_br" (get-dec-precision)))
   ((check-name "exact_real_arith@pvsio.ERAApproxIO__")
    (pvsio-funcall "era_approx.pi_era" (get-dec-precision)))
   (t (rational pi))))

(defattach |sincos_def.sin| (x)
  "Sine of X"
  (cond
   ((check-name "fast_approx@pvsio.FastApproxIO__")
    (pvsio-funcall "fast_approx.sin_fast_approx" x (get-dec-precision)))
   ((check-name "exact_real_arith@pvsio.ERAApproxIO__")
    (pvsio-funcall "era_approx.sin_era" x (get-dec-precision)))
   (t (rational (sin (rat2double x))))))

