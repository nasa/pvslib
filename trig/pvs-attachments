;;-*-Lisp-*-

(defattach |pi_def.pi| ()
  "Number π (by Common Lisp double-precision floating-point)"
  (rational pi))

(defattach |sincos_def.sin| (x)
  "Sine of X (by Common Lisp double-precision floating-point)"
  (rational (sin (rat2double x))))

(defattach |sincos_def.cos| (x)
  "Cosine of X (by Common Lisp double-precision floating-point)"
  (rational (cos (rat2double x))))

(defattach |trig_basic.tan| (x)
  "Tangent of X (by Common Lisp double-precision floating-point)"
  (rational (tan (rat2double x))))

(defattach |atan.atan| (x)
  "Arc tangent of X (by Common Lisp double-precision floating-point)"
  (rational (atan (rat2double x))))
