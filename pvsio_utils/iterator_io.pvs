iterator_io[T:TYPE] : THEORY
BEGIN

  IMPORTING structures@iterator[T],
            finseq_io[T]

  iterator2strf(f:[T->string])(it:Iterator) : MACRO string =
    LET n = length(it) IN
    format("(# length := ~a, next:= ~a, seq := ~a #)",
           {| n, it`next, array2strf[T,n](f)(it`seq) |})
    
  to_str(it:Iterator[T]) : MACRO string =
    iterator2strf(LAMBDA(t:T):format("~a",t))(it)

END iterator_io
