finseq_io[T:TYPE] : THEORY
BEGIN

  IMPORTING arrays_io

  finseq2strf(f:[T->string])(fs:finseq[T]) : MACRO string =
    LET n = length(fs) IN
    format("(# length := ~a, seq := ~a #)",
           {| n, array2strf[T,n](f)(fs`seq) |})

  to_str(fs:finseq[T]) : MACRO string =
    finseq2strf(LAMBDA(t:T):format("~a",t))(fs)

END finseq_io
