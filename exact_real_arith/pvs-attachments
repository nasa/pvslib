;;-*-Lisp-*-

(defun get-nat-precision ()
  (cadr *pvsio-precision*))

(defattach |sqrt.sqrt| (x)
  "Square root of X (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.sqrt_era" x (get-nat-precision)))

(defattach |pi_def.pi| ()
  "Number π (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.pi_era" (get-nat-precision)))

(defattach |sincos_def.sin| (x)
  "Sine of X (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.sin_era" x (get-nat-precision)))

(defattach |sincos_def.cos| (x)
  "Cosine of X (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.cos_era" x (get-nat-precision)))

(defattach |trig_basic.tan| (x)
  "Tangent of X (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.tan_era" x (get-nat-precision)))

(defattach |atan.atan| (x)
  "Arc tangent of X (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.atan_era" x (get-nat-precision)))

(defattach |ln_exp.ln| (x)
  "Natural logarithm of X (by NASALib exact_real_arith)"
  (pvsio-funcall "era_approx.ln_era" x (get-nat-precision)))

(defattach |ln_exp.exp| (x)
