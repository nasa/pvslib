;;-*-Lisp-*-
;;These attachments allow for dynamic binding of functions according to
;;the theories that are imported, e.g., fast_approx@pvsio, exact_real_arith@pvsio

(defattach |ln_exp.ln| (x)
  "Natural logarithm"
  (cond
   ((check-name "exact_real_arith@pvsio.ERAApproxIO__")
    (pvsio-funcall "era_approx.ln_era" x (get-nat-precision)))
   (t (rational (log (rat2double x))))))

(defattach |ln_exp.exp| (x)
  "Exponential"
  (cond
   ((check-name "exact_real_arith@pvsio.ERAApproxIO__")
    (pvsio-funcall "era_approx.exp_era" x (get-nat-precision)))
   (t (rational (exp (rat2double x))))))
