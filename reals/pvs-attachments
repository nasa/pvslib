;;-*-Lisp-*-
;;These attachments allow for dynamic binding of functions according to
;;the theories that are imported, e.g., fast_approx@pvsio, exact_real_arith@pvsio

(defun get-dec-precision ()
  (expt 10 (- (cadr *pvsio-precision*))))

(defun get-nat-precision ()
  (cadr *pvsio-precision*))

(defattach |sqrt.sqrt| (x)
  "Square root of X"
  (cond
   ((check-name "fast_approx@pvsio.FastApproxIO__")
    (pvsio-funcall "fast_approx.sqrt_fast_approx" x (get-dec-precision)))
   ((check-name "exact_real_arith@pvsio.ERAApproxIO__")
    (pvsio-funcall "era_approx.sqrt_era" x (get-nat-precision)))
   (t (rational (sqrt (rat2double x))))))
